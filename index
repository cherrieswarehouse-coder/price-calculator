<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Price Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary: #3A438B;
    --primary-dark: #272e63;
    --primary-light: #eef0f9;
    --primary-mid: #bec5e3;
    --primary-text: #1e2660;
    --bg: #f4f6fb;
    --surface: #ffffff;
    --border: rgba(58,67,139,0.12);
    --border-strong: rgba(58,67,139,0.22);
    --text: #0f1c3a;
    --muted: #5a6a8a;
    --hint: #96a3be;
    --success-bg: #edfaf3;
    --success-border: #7ecfa5;
    --success-text: #166a3d;
    --warn-bg: #fff8ed;
    --warn-border: #f5c97a;
    --warn-text: #8b5200;
    --radius: 14px;
    --radius-sm: 9px;
  }

  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding-bottom: 60px; }

  /* ── NAVBAR ── */
  .navbar {
    background: #3A438B;
    padding: 0 24px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 10;
    gap: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.18);
  }
  .navbar-logo { display: flex; align-items: center; flex-shrink: 0; }
  .navbar-logo img { height: 54px; display: block; }
  .navbar-title {
    font-size: 16px; font-weight: 700; color: #fff;
    letter-spacing: -0.01em; text-align: center;
    flex: 1; line-height: 1.3;
  }

  /* ── RATE BAR ── */
  .rate-bar {
    background: var(--bg);
    padding: 16px 18px 0;
    display: flex;
    justify-content: center;
  }
  .rate-bar-inner {
    max-width: 660px;
    width: 100%;
    background: #f7f5ec;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: var(--radius);
    padding: 10px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .rate-bar-label {
    font-size: 13px; font-weight: 700;
    color: var(--text);
    margin-right: 4px;
    flex-shrink: 0;
  }
  .rate-pill {
    background: rgba(58,67,139,0.09);
    border: 1px solid rgba(58,67,139,0.18);
    color: var(--primary-text);
    font-size: 12px; font-weight: 500;
    padding: 5px 12px; border-radius: 20px;
    display: flex; align-items: center; gap: 6px;
  }
  .rate-dot { width: 6px; height: 6px; border-radius: 50%; background: #7ECFA5; flex-shrink: 0; }

  @media (max-width: 520px) {
    .navbar { padding: 0 14px; height: 60px; }
    .navbar-logo img { height: 44px; }
    .navbar-title { font-size: 13px; }
  }

  /* ── CONTAINER ── */
  .container { max-width: 660px; margin: 0 auto; padding: 14px 18px 0; }

  /* ── CARDS ── */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; margin-bottom: 14px; }

  .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
  .step-badge { width: 24px; height: 24px; background: var(--primary); color: #fff; border-radius: 50%; font-size: 11px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .card-title { font-size: 14px; font-weight: 600; color: var(--text); }

  .field { margin-bottom: 14px; }
  .field:last-child { margin-bottom: 0; }
  label { display: block; font-size: 12px; font-weight: 500; color: var(--muted); margin-bottom: 5px; }

  input[type="text"], input[type="number"], input[type="url"], select {
    width: 100%; height: 40px; padding: 0 12px;
    border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--text);
    background: var(--surface); outline: none; appearance: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  input:focus, select:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(58,67,139,0.10); }
  input::placeholder { color: var(--hint); }
  .hint { font-size: 11.5px; color: var(--hint); margin-top: 5px; line-height: 1.5; }

  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  .url-row { display: flex; gap: 8px; }
  .url-row input { flex: 1; min-width: 0; }

  .open-btn {
    height: 40px; padding: 0 14px; font-size: 13px; font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    border: 1px solid var(--primary); border-radius: var(--radius-sm);
    background: var(--primary-light); color: var(--primary);
    cursor: pointer; white-space: nowrap;
    display: flex; align-items: center; gap: 6px;
    transition: background 0.15s; flex-shrink: 0;
  }
  .open-btn:hover { background: var(--primary-mid); }

  /* ── AI HINT BOX ── */
  .ai-hint-box {
    background: var(--primary-light);
    border: 1px solid var(--primary-mid);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    margin-top: 14px;
  }
  .ai-hint-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .ai-badge { font-size: 10px; font-weight: 600; background: var(--primary); color: #fff; padding: 2px 8px; border-radius: 4px; letter-spacing: 0.04em; }
  .ai-hint-title { font-size: 13px; font-weight: 600; color: var(--primary-text); }
  .ai-hint-body { font-size: 12.5px; color: var(--primary-text); line-height: 1.65; margin-bottom: 10px; opacity: 0.85; }
  .ai-hint-body strong { opacity: 1; font-weight: 600; }

  .prompt-box {
    background: #fff;
    border: 1px solid var(--primary-mid);
    border-radius: 7px;
    padding: 11px 13px;
    font-size: 12.5px; color: var(--primary-text);
    line-height: 1.7; font-family: 'DM Sans', sans-serif;
    white-space: pre-wrap; word-break: break-word;
  }
  .prompt-url-line { color: var(--primary); font-weight: 500; word-break: break-all; }

  .copy-btn {
    margin-top: 9px; height: 32px; padding: 0 14px;
    font-size: 12px; font-weight: 500; font-family: 'DM Sans', sans-serif;
    border: 1px solid var(--primary-mid); border-radius: 6px;
    background: var(--primary-light); color: var(--primary-text);
    cursor: pointer; display: inline-flex; align-items: center; gap: 5px;
    transition: background 0.15s;
  }
  .copy-btn:hover { background: var(--primary-mid); }
  .copy-btn.copied { background: var(--success-bg); color: var(--success-text); border-color: var(--success-border); }
  .ai-disclaimer { font-size: 11.5px; color: var(--primary-text); margin-top: 9px; opacity: 0.6; font-style: italic; }

  .ai-how-to { background: rgba(58,67,139,0.06); border-radius: 7px; padding: 11px 13px; margin-top: 11px; }
  .ai-how-title { display: flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: var(--primary-text); margin-bottom: 9px; }
  .ai-how-steps { display: flex; flex-direction: column; gap: 7px; }
  .ai-how-row { display: flex; align-items: flex-start; gap: 9px; font-size: 12px; color: var(--primary-text); line-height: 1.55; opacity: 0.85; }
  .ai-how-row strong { font-weight: 600; opacity: 1; }
  .ai-how-num { width: 18px; height: 18px; border-radius: 50%; background: var(--primary); color: #fff; font-size: 10px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
  .prompt-box b { font-weight: 600; }

  /* ── JP SHIPPING HELP ── */
  .jp-help {
    font-size: 12px; color: var(--muted);
    background: var(--bg); border-radius: 7px;
    padding: 9px 11px; margin-top: 6px; line-height: 1.55;
  }
  .jp-help a { color: var(--primary); font-weight: 500; text-decoration: none; }
  .jp-help a:hover { text-decoration: underline; }

  /* ── RATE TAG ── */
  .rate-tag { display: inline-block; font-size: 10px; font-weight: 500; padding: 2px 7px; background: var(--primary-light); border: 1px solid var(--primary-mid); border-radius: 4px; color: var(--primary-text); margin-left: 6px; }

  /* ── CALCULATE BUTTON ── */
  .calc-btn {
    width: 100%; height: 52px;
    font-size: 15px; font-weight: 600; font-family: 'DM Sans', sans-serif;
    background: var(--primary); color: #fff;
    border: none; border-radius: var(--radius);
    cursor: pointer; letter-spacing: -0.01em;
    transition: background 0.15s, transform 0.1s;
    margin-bottom: 14px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .calc-btn:hover { background: var(--primary-dark); }
  .calc-btn:active { transform: scale(0.99); }

  /* ── RESULTS ── */
  .results-section { display: none; }
  .results-section.show { display: block; }

  .results-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .metric { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px 15px; }
  .metric.highlight { background: var(--primary); border-color: var(--primary); }
  .m-label { font-size: 10.5px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
  .metric.highlight .m-label { color: rgba(255,255,255,0.55); }
  .m-val { font-size: 20px; font-weight: 600; color: var(--text); letter-spacing: -0.02em; }
  .metric.highlight .m-val { color: #fff; }
  .m-sub { font-size: 11px; color: var(--hint); margin-top: 2px; }
  .metric.highlight .m-sub { color: rgba(255,255,255,0.45); }

  .ship-note { border-radius: var(--radius-sm); padding: 12px 15px; font-size: 13px; line-height: 1.65; margin-bottom: 14px; }
  .ship-note.free { background: var(--success-bg); border: 1px solid var(--success-border); color: var(--success-text); }
  .ship-note.paid { background: var(--warn-bg); border: 1px solid var(--warn-border); color: var(--warn-text); }
  .ship-note strong { font-weight: 600; }

  .breakdown { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 20px; margin-bottom: 14px; }
  .bd-title { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px; }
  .b-row { display: flex; justify-content: space-between; align-items: baseline; padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
  .b-row:last-of-type { border-bottom: none; }
  .b-label { color: var(--muted); }
  .b-val { font-weight: 500; }
  .b-grand { display: flex; justify-content: space-between; align-items: baseline; padding-top: 12px; margin-top: 4px; border-top: 2px solid var(--primary); }
  .b-grand .b-label { font-size: 15px; font-weight: 600; color: var(--text); }
  .b-grand .b-val { font-size: 24px; font-weight: 600; letter-spacing: -0.02em; color: var(--primary); }

  .confirm-note { background: var(--primary-light); border: 1px solid var(--primary-mid); border-radius: var(--radius-sm); padding: 13px 15px; font-size: 12.5px; color: var(--primary-text); line-height: 1.6; text-align: center; margin-bottom: 14px; }
  .confirm-note strong { color: var(--primary); }

  /* ── FOOTER ── */
  .footer { text-align: center; padding: 20px; font-size: 12px; color: var(--hint); }
  .footer a { color: var(--primary); text-decoration: none; font-weight: 500; }

  @media (max-width: 480px) {
    .row2 { grid-template-columns: 1fr; }
    .container { padding: 16px 13px 0; }
    .card { padding: 16px; }
    .m-val { font-size: 17px; }
    .b-grand .b-val { font-size: 20px; }
  }

  /* ── SOCIAL BUTTONS ── */
  .navbar-socials { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .soc-btn {
    width: 34px; height: 34px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; text-decoration: none; flex-shrink: 0;
    transition: opacity 0.15s, transform 0.1s;
  }
  .soc-btn:hover { opacity: 0.85; transform: scale(1.08); }
  .soc-btn svg { width: 17px; height: 17px; }
  .soc-x       { background: #000; }
  .soc-line     { background: #06C755; }
  .soc-alpha    { background: #00B900; }
  .soc-ig       { background: radial-gradient(circle at 30% 110%, #f09433, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888); }
  .soc-fb       { background: #1877F2; }
  .soc-shopee   { background: #EE4D2D; }


  @media (max-width: 520px) {
    .soc-btn { width: 28px; height: 28px; border-radius: 6px; }
    .soc-btn svg { width: 14px; height: 14px; }
    .navbar-socials { gap: 4px; }
  }

  /* ── SHIPPING COMPARE ── */
  .ship-compare {
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    text-align: center;
    border: 1px solid var(--border);
  }
  .ship-sea { background: #eef6ff; border-color: #b8d9f8; }
  .ship-air { background: #fff7ee; border-color: #f8d9b8; }
  .sc-icon { font-size: 22px; line-height: 1; margin-bottom: 4px; }
  .sc-label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
  .sc-val { font-size: 18px; font-weight: 600; color: var(--text); letter-spacing: -0.02em; }
  .sc-sub { font-size: 11px; color: var(--hint); margin-top: 2px; }
  .rate-dot-air { background: #F5A623 !important; }
  .b-grand-wrap { border-top: 2px solid var(--primary); padding-top: 12px; margin-top: 4px; display: flex; flex-direction: column; gap: 8px; }
  .b-grand { display: flex; justify-content: space-between; align-items: baseline; }
  .b-grand .b-label { font-size: 14px; font-weight: 600; color: var(--text); }
  .b-grand .b-val { font-size: 20px; font-weight: 600; letter-spacing: -0.02em; color: var(--primary); }
  .b-grand-air .b-val { color: #b85e00; }
</style>
</head>
<body>

<!-- ── NAVBAR ── -->
<div class="navbar">
  <div class="navbar-logo">
    <img src="data:image/png;base64," alt="CherriesStore Logo" />
  </div>
  <div class="navbar-title">Price Calculator</div>
  <div class="navbar-socials">
    <a class="soc-btn soc-x" href="https://x.com/cherriesstore" target="_blank" title="X (Twitter)">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a class="soc-btn soc-line" href="https://lin.ee/7LHu3HC" target="_blank" title="LINE">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
    </a>
  </div>
</div>

<!-- ── HERO BANNER ── -->
<div class="rate-bar">
  <div class="rate-bar-inner">
    <span class="rate-bar-label">Rate</span>
    <span class="rate-pill"><span class="rate-dot"></span>JPY → THB at ×0.25</span>
    <span class="rate-pill"><span class="rate-dot"></span>🚢 JP → TH ship 250 THB/kg</span><span class="rate-pill"><span class="rate-dot rate-dot-air"></span>✈️ JP → TH air 650 THB/kg</span>
  </div>
</div>

<!-- ── MAIN ── -->
<div class="container">

  <!-- Step 1 -->
  <div class="card">
    <div class="card-header">
      <div class="step-badge">1</div>
      <div class="card-title">Product link</div>
    </div>

    <div class="field">
      <label>Paste the product URL here</label>
      <div class="url-row">
        <input type="url" id="url-input" placeholder="https://www.amazon.co.jp/..." oninput="onUrlChange()" />
        <button class="open-btn" onclick="openProduct()">
          Open
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <!-- AI Hint Box -->
    <div class="ai-hint-box">
      <div class="ai-hint-header">
        <span class="ai-badge">AI TIP</span>
        <span class="ai-hint-title">Let AI check the product details for you</span>
      </div>
      <div class="ai-hint-body">
        Not sure about weight or shipping info? Use <strong>Claude</strong> at <a href="https://claude.ai" target="_blank" style="color:var(--primary);font-weight:600;text-decoration:none;">claude.ai</a> (free) to check the product page for you.<br>
        Copy the prompt below → open Claude → paste it in.
      </div>

      <div class="prompt-box" id="prompt-display">Please check this product page and return the information below, formatted in two sections with a table in each, plus a notes section. Fill in every value you can find or estimate.

Product URL: <span class="prompt-url-line" id="prompt-url-display">[paste your product link above first]</span>

────────────────────────────
SECTION 2 — Product Details
────────────────────────────
| Field                    | Value |
|--------------------------|-------|
| Product price (¥ JPY)    |       |
| Product weight (kg)      |       |
| Packaging weight (kg)    |       |

Notes for Section 2:
- Product weight: check listed specs, or estimate from product type / size / material
- Packaging weight: estimate box, foam padding, and bubble wrap for a collectible figure/toy

────────────────────────────────────
SECTION 3 — Japan Domestic Shipping
────────────────────────────────────
| Field                                    | Value |
|------------------------------------------|-------|
| Free shipping threshold (¥ JPY)          |       |
| Shipping fee if below threshold (¥ JPY)  |       |

────────────────────────────
IMPORTANT NOTES
────────────────────────────
List anything the buyer should know, for example:
- Cannot be combined or shipped with other items
- Oversized / heavy item surcharge
- Pre-order or back-order status
- Fragile item handling
- Adult-only product
- Seller or regional shipping limits
- Anything else that may affect the order

If nothing to note, write: No special notes.</div>

      <button class="copy-btn" id="copy-btn" onclick="copyPrompt()">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="1" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M4 4V2.5A1.5 1.5 0 015.5 1H10.5A1.5 1.5 0 0112 2.5V7.5A1.5 1.5 0 0110.5 9H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        Copy prompt
      </button>

      <!-- How to use results -->
      <div class="ai-how-to">
        <div class="ai-how-title">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><circle cx="6.5" cy="6.5" r="5.5" stroke="currentColor" stroke-width="1.2"/><path d="M6.5 5.5v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="6.5" cy="3.8" r="0.6" fill="currentColor"/></svg>
          How to use Claude's answer
        </div>
        <div class="ai-how-steps">
          <div class="ai-how-row"><span class="ai-how-num">1</span><span>From <strong>Section 2</strong> — fill in product price, product weight, and packaging weight into Step 2 below</span></div>
          <div class="ai-how-row"><span class="ai-how-num">2</span><span>From <strong>Section 3</strong> — fill in free shipping threshold and shipping fee into Step 3 below</span></div>
          <div class="ai-how-row"><span class="ai-how-num">3</span><span>Read <strong>Important Notes</strong> carefully — if anything looks unusual, <a href="https://x.com/cherriesstore" target="_blank" style="color:var(--primary);font-weight:600;text-decoration:none;">contact cherriesstore to confirm</a></span></div>
        </div>
      </div>

      <div class="ai-disclaimer">⚠ AI can make mistakes. When you place your order, we will verify all product details again before asking for your confirmation.</div>
    </div>
  </div>

  <!-- Step 2 -->
  <div class="card">
    <div class="card-header">
      <div class="step-badge">2</div>
      <div class="card-title">Product details</div>
    </div>
    <div class="row2">
      <div class="field">
        <label>Product price (¥ JPY)</label>
        <input type="number" id="price-jpy" placeholder="e.g. 3500" min="0" oninput="liveCalc()" />
      </div>
      <div class="field">
        <label>Quantity</label>
        <input type="number" id="qty" value="1" min="1" oninput="liveCalc()" />
      </div>
    </div>
    <div class="row2">
      <div class="field">
        <label>Product weight (kg)</label>
        <input type="number" id="weight-kg" placeholder="e.g. 0.30" min="0" step="0.01" oninput="liveCalc()" />
        <div class="hint">Check the product specs or use the AI prompt above</div>
      </div>
      <div class="field">
        <label>Packaging weight (kg)</label>
        <input type="number" id="pkg-kg" placeholder="e.g. 0.20" min="0" step="0.01" oninput="liveCalc()" />
        <div class="hint">Box, foam, bubble wrap — use the AI prompt to estimate</div>
      </div>
    </div>
  </div>

  <!-- Step 3 -->
  <div class="card">
    <div class="card-header">
      <div class="step-badge">3</div>
      <div class="card-title">Japan domestic shipping <span class="rate-tag">check product site</span></div>
    </div>
    <div class="row2">
      <div class="field">
        <label>Free shipping threshold (¥ JPY)</label>
        <input type="number" id="jp-free-threshold" placeholder="e.g. 3980" min="0" oninput="liveCalc()" />
      </div>
      <div class="field">
        <label>Shipping fee if below threshold (¥ JPY)</label>
        <input type="number" id="jp-ship-fee" placeholder="e.g. 550" min="0" oninput="liveCalc()" />
        <div class="hint">Enter 0 if always free</div>
      </div>
    </div>
    <div class="jp-help">
      Check the product site for their shipping policy. Look for "送料無料" (free shipping) conditions and the applicable fee — or ask <a href="https://x.com/cherriesstore" target="_blank">cherriesstore</a> for help.
    </div>
  </div>

  <button class="calc-btn" onclick="calculate()">
    <svg width="17" height="17" viewBox="0 0 17 17" fill="none"><rect x="2" y="2" width="13" height="13" rx="2.5" stroke="white" stroke-width="1.4"/><path d="M5.5 8.5h6M8.5 5.5v6" stroke="white" stroke-width="1.4" stroke-linecap="round"/></svg>
    Calculate estimate
  </button>

  <!-- Results -->
  <div class="results-section" id="results">

    <div class="results-grid">
      <div class="metric">
        <div class="m-label">Product price</div>
        <div class="m-val" id="r-product-thb">—</div>
        <div class="m-sub" id="r-product-jpy"></div>
      </div>
      <div class="metric">
        <div class="m-label">Total weight</div>
        <div class="m-val" id="r-weight">—</div>
        <div class="m-sub">product + packaging</div>
      </div>
      <div class="metric" style="grid-column: span 2;">
        <div class="m-label" style="margin-bottom:10px;">JP → TH shipping comparison</div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
          <div class="ship-compare ship-sea">
            <div class="sc-icon">🚢</div>
            <div class="sc-label">Ship</div>
            <div class="sc-val" id="r-intl-sea">—</div>
            <div class="sc-sub">250 THB/kg</div>
          </div>
          <div class="ship-compare ship-air">
            <div class="sc-icon">✈️</div>
            <div class="sc-label">Airplane</div>
            <div class="sc-val" id="r-intl-air">—</div>
            <div class="sc-sub">650 THB/kg</div>
          </div>
        </div>
      </div>
      <div class="metric highlight" style="grid-column: span 2;">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0; align-items:center;">
          <div>
            <div class="m-label">🚢 Total (ship)</div>
            <div class="m-val" id="r-total-sea">—</div>
          </div>
          <div style="border-left: 1px solid rgba(255,255,255,0.2); padding-left:16px;">
            <div class="m-label">✈️ Total (airplane)</div>
            <div class="m-val" id="r-total-air">—</div>
          </div>
        </div>
        <div class="m-sub" style="margin-top:6px; text-align:center;">THB all in</div>
      </div>
    </div>

    <div id="ship-note" style="display:none;"></div>

    <div class="breakdown">
      <div class="bd-title">Breakdown</div>
      <div class="b-row"><span class="b-label">Product price (JPY × 0.25)</span><span class="b-val" id="b-product">—</span></div>
      <div class="b-row"><span class="b-label">Japan domestic shipping</span><span class="b-val" id="b-jpship">—</span></div>
      <div class="b-row">
        <span class="b-label">🚢 JP → TH shipping (ship)</span>
        <span class="b-val" id="b-intl-sea">—</span>
      </div>
      <div class="b-row">
        <span class="b-label">✈️ JP → TH shipping (airplane)</span>
        <span class="b-val" id="b-intl-air">—</span>
      </div>
      <div class="b-grand-wrap">
        <div class="b-grand">
          <span class="b-label">🚢 Total (ship)</span>
          <span class="b-val" id="b-total-sea">—</span>
        </div>
        <div class="b-grand b-grand-air">
          <span class="b-label">✈️ Total (airplane)</span>
          <span class="b-val" id="b-total-air">—</span>
        </div>
      </div>
    </div>

    <div class="confirm-note">
      <strong>Please note:</strong> This is an estimate only. When you place your order, we will verify all product details and shipping costs again before sending you a final confirmation.
    </div>

  </div>

  <div class="footer">CherriesStore &mdash; Japan to Thailand</div>

</div>

<script>
  const RATE = 0.25, SHIP_SEA = 250, SHIP_AIR = 650, SHIP_MIN = 30;
  const fmtTHB = n => Math.round(n).toLocaleString() + ' THB';
  const fmtJPY = n => '¥' + Math.round(n).toLocaleString();
  const fmtKg  = n => parseFloat(n.toFixed(2)) + ' kg';

  function openProduct() {
    const u = document.getElementById('url-input').value.trim();
    if (u) window.open(u, '_blank');
  }

  function onUrlChange() {
    const url = document.getElementById('url-input').value.trim();
    const display = document.getElementById('prompt-url-display');
    if (url) {
      display.textContent = url;
    } else {
      display.textContent = '[paste your product link above first]';
    }
    liveCalc();
  }

  function copyPrompt() {
    const url = document.getElementById('url-input').value.trim();
    const urlLine = url || '[paste your product link here]';
    const text = `Please check this product page and return the information below, formatted in two sections with a table in each, plus a notes section. Fill in every value you can find or estimate.\n\nProduct URL: ${urlLine}\n\n────────────────────────────\nSECTION 2 — Product Details\n────────────────────────────\n| Field                    | Value |\n|--------------------------|-------|\n| Product price (¥ JPY)    |       |\n| Product weight (kg)      |       |\n| Packaging weight (kg)    |       |\n\nNotes for Section 2:\n- Product weight: check listed specs, or estimate from product type / size / material\n- Packaging weight: estimate box, foam padding, and bubble wrap for a collectible figure/toy\n\n────────────────────────────────────\nSECTION 3 — Japan Domestic Shipping\n────────────────────────────────────\n| Field                                    | Value |\n|------------------------------------------|-------|\n| Free shipping threshold (¥ JPY)          |       |\n| Shipping fee if below threshold (¥ JPY)  |       |\n\n────────────────────────────\nIMPORTANT NOTES\n────────────────────────────\nList anything the buyer should know, for example:\n- Cannot be combined or shipped with other items\n- Oversized / heavy item surcharge\n- Pre-order or back-order status\n- Fragile item handling\n- Adult-only product\n- Seller or regional shipping limits\n- Anything else that may affect the order\n\nIf nothing to note, write: No special notes.`;

    const btn = document.getElementById('copy-btn');
    navigator.clipboard.writeText(text).then(() => {
      btn.classList.add('copied');
      btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2 7L5 10L11 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Copied!';
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="1" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M4 4V2.5A1.5 1.5 0 015.5 1H10.5A1.5 1.5 0 0112 2.5V7.5A1.5 1.5 0 0110.5 9H9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg> Copy prompt';
      }, 2500);
    }).catch(() => {
      const range = document.createRange();
      range.selectNodeContents(document.getElementById('prompt-display'));
      const sel = window.getSelection();
      sel.removeAllRanges();
      sel.addRange(range);
    });
  }

  function liveCalc() {
    if (document.getElementById('results').classList.contains('show')) calculate();
  }

  function calculate() {
    const priceJPY  = parseFloat(document.getElementById('price-jpy').value) || 0;
    const qty       = Math.max(1, parseInt(document.getElementById('qty').value) || 1);
    const wKg       = parseFloat(document.getElementById('weight-kg').value) || 0;
    const pKg       = parseFloat(document.getElementById('pkg-kg').value) || 0;
    const threshold = parseFloat(document.getElementById('jp-free-threshold').value);
    const jpFee     = parseFloat(document.getElementById('jp-ship-fee').value) || 0;

    const totalJPY   = priceJPY * qty;
    const productTHB = totalJPY * RATE;
    const totalWeight = (wKg * qty) + pKg;
    const intlSeaTHB = Math.max(totalWeight * SHIP_SEA, SHIP_MIN);
    const intlAirTHB = Math.max(totalWeight * SHIP_AIR, SHIP_MIN);

    let jpShipJPY = 0;
    const noteEl = document.getElementById('ship-note');

    if (!isNaN(threshold) && threshold > 0) {
      noteEl.style.display = 'block';
      if (totalJPY >= threshold) {
        jpShipJPY = 0;
        noteEl.className = 'ship-note free';
        noteEl.innerHTML = `This site offers <strong>free shipping</strong> on orders over <strong>${fmtJPY(threshold)}</strong>. Your order of <strong>${fmtJPY(totalJPY)}</strong> qualifies — no Japan domestic shipping fee.`;
      } else {
        jpShipJPY = jpFee;
        const diff = threshold - totalJPY;
        noteEl.className = 'ship-note paid';
        noteEl.innerHTML = `This site offers free shipping on orders over <strong>${fmtJPY(threshold)}</strong>. Your order of <strong>${fmtJPY(totalJPY)}</strong> has not reached the threshold — a Japan domestic shipping fee of <strong>${fmtJPY(jpShipJPY)}</strong> (${fmtTHB(jpShipJPY * RATE)}) applies. Add <strong>${fmtJPY(diff)}</strong> more to qualify for free shipping.`;
      }
    } else {
      noteEl.style.display = 'none';
    }

    const jpShipTHB  = jpShipJPY * RATE;
    const grandSea   = productTHB + jpShipTHB + intlSeaTHB;
    const grandAir   = productTHB + jpShipTHB + intlAirTHB;

    document.getElementById('r-product-thb').textContent = fmtTHB(productTHB);
    document.getElementById('r-product-jpy').textContent = fmtJPY(totalJPY) + ' × 0.25';
    document.getElementById('r-weight').textContent = fmtKg(totalWeight);
    document.getElementById('r-intl-sea').textContent = fmtTHB(intlSeaTHB);
    document.getElementById('r-intl-air').textContent = fmtTHB(intlAirTHB);
    document.getElementById('r-total-sea').textContent = fmtTHB(grandSea);
    document.getElementById('r-total-air').textContent = fmtTHB(grandAir);

    document.getElementById('b-product').textContent = fmtTHB(productTHB);
    document.getElementById('b-jpship').textContent = jpShipJPY > 0 ? fmtTHB(jpShipTHB) : 'Free';
    document.getElementById('b-intl-sea').textContent = fmtTHB(intlSeaTHB);
    document.getElementById('b-intl-air').textContent = fmtTHB(intlAirTHB);
    document.getElementById('b-total-sea').textContent = fmtTHB(grandSea);
    document.getElementById('b-total-air').textContent = fmtTHB(grandAir);

    const res = document.getElementById('results');
    res.classList.add('show');
    setTimeout(() => res.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
  }
</script>
</body>
</html>
